# ══════════════════════════════════════════════════════════════════
# VowConnect — Environment Variables
# Copy this to .env.local and fill in your values
# cp .env.example .env.local
# ══════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://postgres:yourpassword@localhost:5432/vowconnect
# Neon / Supabase / Vercel Postgres: use the connection string from dashboard
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/vowconnect"

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://vowconnect.com"

# ── Auth ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string-minimum-32-chars"

# ── Super Admin ─────────────────────────────────────────────────
# This email gets SUPER_ADMIN role automatically on registration
SUPER_ADMIN_EMAIL="your-admin@example.com"

# ── Email (Resend) ───────────────────────────────────────────────
# Sign up free at resend.com — 3,000 emails/month on free tier
# Required for: verification emails, booking notifications, password reset
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="VowConnect <hello@vowconnect.com>"
RESEND_ADMIN_EMAIL="admin@vowconnect.com"

# ── Google OAuth ─────────────────────────────────────────────────
# Setup: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
# Production:              https://vowconnect.com/api/auth/google/callback
GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxxx"

# ── Payments: Stripe (UK/US/international) ──────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional: create products in Stripe dashboard and add price IDs
# STRIPE_PRO_PRICE_ID="price_xxxxxxxx"
# STRIPE_PREMIUM_PRICE_ID="price_xxxxxxxx"

# ── Payments: Paystack (Nigeria / Ghana / Kenya) ─────────────────
# dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── File Uploads: Cloudinary ─────────────────────────────────────
# cloudinary.com → Dashboard → API Keys (free tier: 25GB storage)
# If not set, portfolio images are stored as base64 (dev only — not for production!)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"

# ── Maps (optional) ──────────────────────────────────────────────
# console.cloud.google.com → Maps JavaScript API
# Needed for the /map page — page still works without it (shows list view)
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Instagram Integration (optional) ────────────────────────────
# developers.facebook.com → My Apps → Instagram Basic Display
INSTAGRAM_CLIENT_ID="your_instagram_app_id"
INSTAGRAM_CLIENT_SECRET="your_instagram_app_secret"

# ── WhatsApp Business API (optional) ─────────────────────────────
# developers.facebook.com → WhatsApp → Getting Started
# Free tier: 1,000 conversations/month. Without this, WA buttons still work
# (direct chat links) — this enables automated booking notifications via WA.
WHATSAPP_PHONE_NUMBER_ID="123456789012345"
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WHATSAPP_VERIFY_TOKEN="any-secret-string-you-choose"

# ══════════════════════════════════════════════════════════════════
# QUICK START
# ══════════════════════════════════════════════════════════════════
# Minimum required to run locally:
#   DATABASE_URL
#   JWT_SECRET
#   SUPER_ADMIN_EMAIL
#   NEXT_PUBLIC_APP_URL (already set to localhost)
#
# Everything else degrades gracefully:
#   - No RESEND_API_KEY → emails logged to console
#   - No GOOGLE_* → "Sign in with Google" button hidden
#   - No CLOUDINARY_* → portfolio stored as base64 (dev only)
#   - No STRIPE_*/PAYSTACK_* → payment buttons disabled
#   - No GOOGLE_MAPS_KEY → /map shows list view only
#   - No WHATSAPP_* → direct WA links still work
# ══════════════════════════════════════════════════════════════════
